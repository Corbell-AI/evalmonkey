# Evalmonkey Environment Setup

# ----------------------------------------
# 1. Choose your Primary Agent Evaluation Model
# ----------------------------------------
# The local sample apps (`rag_app` & `research_agent`) will automatically route to whatever 
# litellm provider you specify here! 
# Examples: "gpt-4o", "gemini/gemini-1.5-pro", "ollama/gemma", "bedrock/anthropic.claude-3-haiku-20240307-v1:0"
EVAL_MODEL="gpt-4o"

# ----------------------------------------
# 2. Supply Provider Credentials
# ----------------------------------------
# Provide the keys for whichever model you selected above.

# ---- AWS Bedrock ----
# You can use standard AWS IAM variables:
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION_NAME="us-east-1"

# ALTERNATIVELY, if you use a proxy/long-lived static API key for Bedrock:
# Just supply the long term key! EvalMonkey's litellm integration supports long-lived stateless keys automatically.
BEDROCK_API_KEY="..."

# ---- Ollama / Local Models ----
# Natively supported via litellm!
OLLAMA_API_BASE="http://localhost:11434"

# ---- OpenAI ----
OPENAI_API_KEY="sk-..."

# ---- Anthropic ----
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Azure OpenAI ----
# (You can use long-lived stateless keys here as well via AZURE_API_KEY)
AZURE_API_KEY="..."
AZURE_API_BASE="..."
AZURE_API_VERSION="..."

# ---- GCP Vertex AI ----
VERTEXAI_PROJECT="..."
VERTEXAI_LOCATION="..."
# (Also typically requires GOOGLE_APPLICATION_CREDENTIALS path)

# ----------------------------------------
# 3. Eval Asset Generation (Optional)
# ----------------------------------------
# Score below this threshold triggers automatic eval asset generation.
# Default: 70  (i.e. < 70/100 = failure needing improvement)
EVAL_SCORE_THRESHOLD=70

# ----------------------------------------
# 4. Langfuse Integration (Optional — only needed for cloud eval export)
# ----------------------------------------
# EvalMonkey works perfectly WITHOUT Langfuse.
# Configure this ONLY if you want to automatically push generated improvement
# evals to a Langfuse dataset for team sharing or LLM-as-judge workflows.
#
# Get your keys from: https://cloud.langfuse.com → Settings → API Keys
# Self-hosted: set LANGFUSE_HOST to your instance URL.
#
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."
# LANGFUSE_HOST="https://cloud.langfuse.com"  # default; change for self-hosted

# Name of the Langfuse dataset where failing evals are pushed.
# Used by: evalmonkey generate-evals --langfuse-dataset <name>
#          demo_rag_app.sh (automatic if keys are set)
# LANGFUSE_DATASET="evalmonkey_failures"

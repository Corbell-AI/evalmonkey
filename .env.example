# Evalmonkey Environment Setup

# ----------------------------------------
# 1. Choose your Primary Agent Evaluation Model
# ----------------------------------------
# The local sample apps (`rag_app` & `research_agent`) will automatically route to whatever 
# litellm provider you specify here! 
# Examples: "gpt-4o", "gemini/gemini-1.5-pro", "ollama/gemma", "bedrock/anthropic.claude-3-haiku-20240307-v1:0"
EVAL_MODEL="gpt-4o"

# ----------------------------------------
# 2. Supply Provider Credentials
# ----------------------------------------
# Provide the keys for whichever model you selected above.

# ---- AWS Bedrock ----
# You can use standard AWS IAM variables:
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION_NAME="us-east-1"

# ALTERNATIVELY, if you use a proxy/long-lived static API key for Bedrock:
# Just supply the long term key! EvalMonkey's litellm integration supports long-lived stateless keys automatically.
BEDROCK_API_KEY="..."

# ---- Ollama / Local Models ----
# Natively supported via litellm!
OLLAMA_API_BASE="http://localhost:11434"

# ---- OpenAI ----
OPENAI_API_KEY="sk-..."

# ---- Anthropic ----
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Azure OpenAI ----
# (You can use long-lived stateless keys here as well via AZURE_API_KEY)
AZURE_API_KEY="..."
AZURE_API_BASE="..."
AZURE_API_VERSION="..."

# ---- GCP Vertex AI ----
VERTEXAI_PROJECT="..."
VERTEXAI_LOCATION="..."
# (Also typically requires GOOGLE_APPLICATION_CREDENTIALS path)
